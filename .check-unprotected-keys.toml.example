# Curated expanded default catalog.
# Excluded by default: public-only files such as *.pub or known_hosts,
# certificate-only outputs such as *.crt or *.csr, unsupported keystore
# families such as *.p12 or *.jks, generic structured config formats such as
# *.json or *.yaml, and generic token-hunting globs.
# Matching findings stay on stdout as canonical paths. Operator-safe malformed
# file logs and low-friction protection guidance are emitted on stderr.
[scan]
base_folders = [
  "~",
]

directory_names = [
  ".ssh", "ssh",
  "secrets", "keys", "private",
  "certs", "certificates", "tls", "ssl", "pki",
  "deploy", "deployment", "infra",
  "ansible", "terraform",
  "docker", "helm", "k8s", "kubernetes",
  "vpn", "openvpn", "wireguard",
  "Docs", "OneDrive", "Insync",
  "gnupg", "private-keys-v1.d",
  "JetBrains", "PyCharm", "Cursor", "Code",
  "History",
]

ignore_directories = [
  "tests",
  # Version control
  ".git", ".svn", ".hg",
  # Dependencies and package install trees
  "node_modules", "bower_components", "vendor",
  ".npm", ".yarn", ".pnpm-store",
  # Python / virtual environments
  ".venv", "venv", "env",
  # Build output
  "target", "dist", "build", "out",
  # Caches
  "__pycache__", ".pytest_cache", ".mypy_cache", ".ruff_cache",
  ".coverage", "coverage", ".cache", ".turbo", ".gradle",
  # IDE / editor metadata
  ".idea", ".vscode", ".vs",
  # Temporary directories
  "tmp", "temp", ".tmp",
  # Note: ".env" here is a directory name, not .env files
  ".env",
  "android-ndk",
  ".stryker-tmp"
]

filename_patterns = [
  "id_*",
  "identity",
  "ssh_host_*_key",
  "*.ppk",
  "*.pem",
  "*.key",
  "*.asc",
  ".env",
  ".env.*",
  "*.env",
  "*.env.*",
  "*.ovpn",
  "*.tfvars"
]

ignore_filename_patterns = [
  ".env.sample", ".env.example", ".env.encrypted",
  # Public-only artifacts
  "*.pub", "authorized_keys", "known_hosts",
  # Certificate-only outputs
  "*.crt", "*.cer", "*.csr",
  # Unsupported keystore families
  "*.p12", "*.pfx", "*.jks", "*.keystore", "*.der", "*.pk8",
  # Cache artifacts
  "*.cache", "*.pyc",
  # Package-manager artifacts
  "package-lock.json", "yarn.lock", "pnpm-lock.yaml",
  "*.whl", "*.egg", "Cargo.lock", "go.sum",
]

max_directory_visits = 100000
